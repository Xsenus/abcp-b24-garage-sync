# ABCP
# Допустимы варианты /cp/garage, /cp/garage/, /cp/garage/list.
# Если случайно указать /cp/users, клиент попробует автоматически заменить его на /cp/garage.
ABCP_BASE_URL=https://abcp61741.public.api.abcp.ru/cp/garage/
ABCP_USERLOGIN=
ABCP_USERPSW=
# Сейчас читается из env, но текущая версия кода не отправляет этот параметр в ABCP.
ABCP_LIMIT=500
# Если сервис запускается без --from/--to и без fetch_state,
# старт берётся с 1 января года now.year - ABCP_INITIAL_LOOKBACK_YEARS.
ABCP_INITIAL_LOOKBACK_YEARS=2
# Overlap между последовательными автоматическими загрузками из ABCP.
ABCP_INCREMENTAL_OVERLAP_MINUTES=5

# Bitrix24
B24_WEBHOOK_URL=
B24_DEAL_CATEGORY_ID_USERS=0
B24_DEAL_TITLE_PREFIX=ABCP Регистрация:
# Смещение для datetime-полей Bitrix24.
B24_TZ_OFFSET=+03:00

# Обязательное поле для поиска сделки по пользователю ABCP.
UF_B24_DEAL_ABCP_USER_ID=

# Дополнительный маппинг полей гаража в UF-поля Bitrix24.
# Если переменная не задана, соответствующее поле не синхронизируется.
#UF_B24_DEAL_GARAGE_ID=
#UF_B24_DEAL_GARAGE_USER_ID=
#UF_B24_DEAL_GARAGE_NAME=
#UF_B24_DEAL_GARAGE_COMMENT=
#UF_B24_DEAL_GARAGE_YEAR=
#UF_B24_DEAL_GARAGE_VIN=
#UF_B24_DEAL_GARAGE_FRAME=
#UF_B24_DEAL_GARAGE_MILEAGE=
#UF_B24_DEAL_GARAGE_MANUFACTURER_ID=
#UF_B24_DEAL_GARAGE_MANUFACTURER=
#UF_B24_DEAL_GARAGE_MODEL_ID=
#UF_B24_DEAL_GARAGE_MODEL=
#UF_B24_DEAL_GARAGE_MODIFICATION_ID=
#UF_B24_DEAL_GARAGE_MODIFICATION=
#UF_B24_DEAL_GARAGE_DATE_UPDATED=
#UF_B24_DEAL_GARAGE_VEHICLE_REG_PLATE=

# Storage
# Корневая директория runtime-данных. Относительные SQLITE_PATH и LOG_DIR
# будут разрешаться относительно неё.
ABCP_B24_DATA_DIR=./data
SQLITE_PATH=abcp_b24.s3db
LOG_DIR=./logs
LOG_FILE=service.log
LOG_LEVEL=INFO

# HTTP
REQUESTS_TIMEOUT=20
REQUESTS_RETRIES=3
REQUESTS_RETRY_BACKOFF=1.5
RATE_LIMIT_SLEEP=0.2
# Пишет отдельный JSONL-аудит исходящих HTTP-запросов в LOG_DIR/http-requests-YYYY-MM-DD.jsonl
REQUEST_AUDIT_ENABLED=true
# Повторно читает сделку после обновления и проверяет применение полей.
B24_VERIFY_UPDATES=false
# Использует Bitrix batch API для find/get/update.
B24_USE_BATCH=true
# Количество команд в одном batch-вызове Bitrix24.
B24_BATCH_SIZE=25

# Sync
# Общее правило перезаписи поддерживаемых полей.
SYNC_OVERWRITE_DEFAULT=true
# Точечные переопределения, пример: {"vin": false, "vehicleRegPlate": false}
SYNC_OVERWRITE_FIELDS={}
SYNC_PAUSE_BETWEEN_USERS=0
SYNC_PAUSE_BETWEEN_DEALS=0
